# LLM API configuration
# Default: OpenRouter (lets you switch models without code changes)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# To use Anthropic directly instead, uncomment these:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Model overrides (optional — defaults to Anthropic Claude)
# Any model supported by your provider works via OpenRouter:
#   google/gemini-2.0-flash, openai/gpt-4o, meta-llama/llama-3.1-70b-instruct, etc.
# MODEL_FAST=anthropic/claude-haiku-4.5
# MODEL_STRONG=anthropic/claude-sonnet-4.6
